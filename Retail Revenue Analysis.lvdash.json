{
  "datasets": [
    {
      "name": "1bb727fb",
      "displayName": "Orders and Customers",
      "queryLines": [
        "SELECT\n",
        "  o_orderdate,\n",
        "  o_custkey\n",
        "FROM\n",
        "  `samples`.`tpch`.`orders`"
      ]
    },
    {
      "name": "3530ec9c",
      "displayName": "Orders vs Returns",
      "queryLines": [
        "SELECT\n",
        "    l_shipdate,\n",
        "    l_suppkey,\n",
        "    COUNT(l_orderkey) AS total_orders,\n",
        "    SUM(CASE WHEN l_returnflag = 'R' THEN 1 ELSE 0 END) AS return_count\n",
        "FROM\n",
        "    samples.tpch.lineitem\n",
        "GROUP BY\n",
        "    l_shipdate,\n",
        "    l_suppkey\n",
        "ORDER BY\n",
        "    l_shipdate;"
      ]
    },
    {
      "name": "a91573ca",
      "displayName": "Late Orders",
      "queryLines": [
        "SELECT COUNT(*) AS late_orders\n",
        "FROM `samples`.`tpch`.`lineitem`\n",
        "WHERE `l_shipdate` > `l_commitdate`"
      ]
    },
    {
      "name": "ced91012",
      "displayName": "Total Revenue by nation and year",
      "queryLines": [
        "SELECT\n",
        "    DATE_FORMAT(`o`.`o_orderdate`, 'yyyy') AS `Year`,\n",
        "    `n`.`n_name` AS `Nation`,\n",
        "    SUM(`o`.`o_totalprice`) AS `Revenue`\n",
        "FROM\n",
        "    `samples`.`tpch`.`orders` AS `o`\n",
        "JOIN\n",
        "    `samples`.`tpch`.`customer` AS `c` \n",
        "ON\n",
        "    `o`.`o_custkey` = `c`.`c_custkey`\n",
        "JOIN\n",
        "    `samples`.`tpch`.`nation` AS `n`\n",
        "ON\n",
        "    `c`.`c_nationkey` = `n`.`n_nationkey`\n",
        "GROUP BY\n",
        "    `Year`,\n",
        "    `Nation`\n",
        "ORDER BY\n",
        "    `Year` ASC,\n",
        "    `Nation` ASC;"
      ]
    },
    {
      "name": "e7a62da2",
      "displayName": "Most common Shipment modes",
      "queryLines": [
        "SELECT `l_shipmode`, COUNT(*) AS `count`\n",
        "FROM `samples`.`tpch`.`lineitem`\n",
        "GROUP BY `l_shipmode`\n",
        "ORDER BY `count` DESC"
      ]
    },
    {
      "name": "ee8e48ce",
      "displayName": "Total Revenue by Customer segment",
      "queryLines": [
        "SELECT\n",
        "  customers.c_mktsegment AS Customer_Segment,\n",
        "  SUM(orders.o_totalprice) AS Total_Segment_Revenue\n",
        "FROM\n",
        "  `samples`.`tpch`.`orders` AS orders\n",
        "JOIN\n",
        "  `samples`.`tpch`.`customer` AS customers\n",
        "    ON orders.o_custkey = customers.c_custkey\n",
        "GROUP BY\n",
        "  customers.c_mktsegment\n",
        "ORDER BY\n",
        "  Total_Segment_Revenue DESC"
      ]
    }
  ],
